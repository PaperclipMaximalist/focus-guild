# ─────────────────────────────────────────────────────────────────────────────
# Focus Guild — client env
#
# Copy this file to `.env` for local dev, or paste these as separate vars
# into Vercel's Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — URL of the deployed server.
# Dev:   http://localhost:3000
# Prod:  https://focus-guild-api.up.railway.app   (or whatever your Railway URL is)
VITE_API_URL=http://localhost:3000

# ─── Optional: real auth ─────────────────────────────────────────────────────
# When set, the client renders Clerk's sign-in UI and sends Authorization:
# Bearer <jwt> on every request. When empty, the client sends
# X-Dev-Clerk-Id: dev-member-001 (single-user dev mode — the server middleware
# accepts this only when CLERK_SECRET_KEY is also unset).
# Grab the publishable key from clerk.com → your app → API Keys.
VITE_CLERK_PUBLISHABLE_KEY=
