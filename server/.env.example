# ─────────────────────────────────────────────────────────────────────────────
# Focus Guild — server env
#
# Copy this file to `.env` for local dev, or paste these as separate vars
# into Railway's "Variables" tab for production.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — Postgres connection string (Neon recommended)
# Example: postgresql://USER:PASS@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# REQUIRED in production — comma-separated list of allowed client origins.
# Dev fallback: http://localhost:5173
# Example: https://focus-guild.vercel.app,https://www.your-domain.com
CLIENT_URL=

# Port the server listens on. Railway sets this automatically; locally
# defaults to 3000.
PORT=

# ─── Optional: real auth ─────────────────────────────────────────────────────
# When set, the auth middleware ONLY accepts verified Clerk Bearer tokens —
# the X-Dev-Clerk-Id / ?clerkId= back doors are refused (prevents impersonation).
# When empty, dev fallback is enabled: X-Dev-Clerk-Id > ?clerkId= > dev-member-001.
# Grab the secret key from clerk.com → your app → API Keys (sk_test_… or sk_live_…).
CLERK_SECRET_KEY=

# ─── Optional: AI features ───────────────────────────────────────────────────
# Required for the "Break down with AI" Quest Decomposer.
# Without it, the /quests/:id/decompose endpoint returns 503.
ANTHROPIC_API_KEY=
